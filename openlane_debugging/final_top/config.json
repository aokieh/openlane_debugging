{
    "//": "1. Design Files & Metadata",
    "DESIGN_NAME": "final_top",
    "VERILOG_FILES": [
        "dir::verilog_final/defines.sv",
        "dir::verilog_final/fifo_intf3.sv",
        "dir::verilog_final/sync_fifo.sv",
        "dir::verilog_final/sync_fifo_top3.sv",
        "dir::verilog_final/spi_peripheral_final.sv",
        "dir::verilog_final/regfile.sv",
        "dir::verilog_final/row_scanner.sv",
        "dir::verilog_final/roic_sm2.sv",
        "dir::verilog_final/row_decoder_macro2.sv",
        "dir::verilog_final/col_readout_macro.sv",
        "dir::verilog_final/fifo_rows_cols_macro2.sv",
        "dir::verilog_final/final_top2_final.sv"
    ],
    "meta": {
        "version": 2
    },

    "//": "2. Linter & Logic Synthesis (Strict Signoff)",
    "SYNTH_HIERARCHY_MODE": "flatten",
    "VERILOG_POWER_DEFINE": "USE_POWER_PINS",
    "ERROR_ON_LINTER_ERRORS": true,
    "ERROR_ON_LINTER_TIMING_CONSTRUCTS": true,
    "ERROR_ON_LINTER_WARNINGS": true,
    "ERROR_ON_NL_ASSIGN_STATEMENTS": true,
    "ERROR_ON_UNMAPPED_CELLS": true,
    "ERROR_ON_SYNTH_CHECKS": true,
    "LINTER_ERROR_ON_LATCH": true,

    "//": "3. Floorplanning & Power Distribution Network (PDN)",
    "FP_PIN_ORDER_CFG": "dir::pin_order.cfg",
    "FP_SIZING": "absolute",
    "DIE_AREA": [0, 0, 720, 720],
    "FP_ASPECT_RATIO": 1.0,
    "PL_TARGET_DENSITY_PCT": 46,
    "VDD_NETS": ["vccd1"],
    "GND_NETS": ["vssd1"],
    "FP_PDN_MULTILAYER": true,
    "FP_PDN_ENABLE_RAILS": true,
    "FP_PDN_CORE_RING": false,
    "FP_PDN_VPITCH": 140,
    "FP_PDN_HPITCH": 140,
    "FP_PDN_VWIDTH": 3,
    "FP_PDN_HWIDTH": 3,
    "FP_PDN_VOFFSET": 5,
    "FP_PDN_HOFFSET": 5,

    "//": "4. Timing, Clock & Constraints",
    "CLOCK_PERIOD": 20,
    "CLOCK_PORT": "clk",
    "CLOCK_NET": "clk",
    "FALLBACK_SDC_FILE": "dir::final_top.sdc",
    "PNR_SDC_FILE": "dir::final_top.sdc",
    "SIGNOFF_SDC_FILE": "dir::final_top.sdc",
    "DEFAULT_CORNER": "max_ss_100C_1v60",
    "MAX_TRANSITION_CONSTRAINT": 1.5,
    "MAX_FANOUT_CONSTRAINT": 16,

    "//": "5. Placement, Resizer & Design Repair",
    "GPL_CELL_PADDING": 1,
    "DPL_CELL_PADDING": 1,
    "SYNTH_ABC_BUFFERING": true,
    "PL_WIRE_LENGTH_COEF": 0.05,
    "RUN_POST_GPL_DESIGN_REPAIR": true,
    "RUN_POST_GRT_DESIGN_REPAIR": true,
    "RUN_POST_CTS_RESIZER_TIMING": true,
    "DESIGN_REPAIR_BUFFER_INPUT_PORTS": true,
    "DESIGN_REPAIR_BUFFER_OUTPUT_PORTS": true,
    "DESIGN_REPAIR_MAX_SLEW_PCT": 30,
    "DESIGN_REPAIR_MAX_CAP_PCT": 30,
    "DESIGN_REPAIR_MAX_WIRE_LENGTH": 300,
    "GRT_RESIZER_DESIGN_OPTIMIZATIONS": true,
    "GRT_RESIZER_TIMING_OPTIMIZATIONS": true,
    "PL_RESIZER_ALLOW_SETUP_VIOS": false,
    "GRT_RESIZER_ALLOW_SETUP_VIOS": false,
    "PL_RESIZER_SETUP_SLACK_MARGIN": 0.4,
    "PL_RESIZER_HOLD_SLACK_MARGIN": 0.1,
    "GRT_RESIZER_SETUP_SLACK_MARGIN": 0.2,
    "GRT_RESIZER_HOLD_SLACK_MARGIN": 0.2,

    "//": "Placement Constraints for Analog Boundary Buffers",    
    "//": "Ensure Resizer does not destroy the FO4 chains",
    "RSZ_DONT_TOUCH_RX": "analog_drvr_stg2_.*",

    "//": "6. Routing & Antenna Protection",
    "CTS_CLK_MAX_WIRE_LENGTH": 400,
    "RUN_HEURISTIC_DIODE_INSERTION": false,
    "RUN_ANTENNA_REPAIR": true,
    "HEURISTIC_ANTENNA_THRESHOLD": 120,
    "GRT_ANTENNA_ITERS": 80,
    "GRT_ANTENNA_MARGIN": 15,
    "pdk::sky130*": {
        "RT_MAX_LAYER": "met4",
        "scl::sky130_fd_sc_hd": {
            "CLOCK_PERIOD": 20
        }
    },

    "//": "7. Physical Verification & Signoff (Strict Signoff)",
    "RUN_KLAYOUT_DRC": true,
    "RUN_MAGIC_DRC": true,
    "RUN_LVS": true,
    "RUN_IRDROP_REPORT": true,
    "MAGIC_DRC_USE_GDS": true,
    "MAGIC_DEF_LABELS": false,
    "ERROR_ON_KLAYOUT_DRC": true,
    "ERROR_ON_MAGIC_DRC": true,
    "ERROR_ON_LVS_ERROR": true,
    "ERROR_ON_TR_DRC": true,
    "ERROR_ON_PDN_VIOLATIONS": true,
    "ERROR_ON_DISCONNECTED_PINS": true,
    "ERROR_ON_LONG_WIRE": true,
    "ERROR_ON_XOR_ERROR": true
}